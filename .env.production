# Production environment variables

# Frontend (Vercel)
VITE_SERVER_URL=https://the-commons-server.fly.dev
VITE_ENV=production

# Backend (Fly.io)
NODE_ENV=production
CLIENT_URL=https://your-vercel-app.vercel.app
PORT=3000

# Redis (add Redis instance URL if using Redis for scaling)
# REDIS_URL=redis://your-redis-instance.com:6379

# Email (for magic links - configure with your email service)
# EMAIL_FROM=noreply@yourapp.com
# EMAIL_API_KEY=your-email-service-api-key